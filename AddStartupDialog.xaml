<Window x:Class="StartupManagerPro.AddStartupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加启动项" Height="550" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" CornerRadius="10" Padding="15,12" Margin="0,0,0,20" Background="#1976D2">
            <TextBlock Text="添加新的启动项" FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>
        
        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="10" BorderBrush="#BBDEFB" BorderThickness="1" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="名称:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1976D2"/>
                    <TextBox x:Name="NameBox" Grid.Column="1" Padding="12,10" BorderBrush="#2196F3" BorderThickness="1" FontSize="13"/>
                </Grid>
                
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="路径:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1976D2"/>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PathBox" Grid.Column="0" Padding="12,10" BorderBrush="#2196F3" BorderThickness="1" Margin="0,0,10,0" FontSize="13"/>
                        <Button Grid.Column="1" Content="浏览" Click="Browse_Click" Padding="12,10" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                    </Grid>
                </Grid>
                
                <Grid Grid.Row="2" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="类型:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1976D2"/>
                    <ComboBox x:Name="TypeBox" Grid.Column="1" Padding="12,10" BorderBrush="#2196F3" BorderThickness="1" FontSize="13" SelectionChanged="TypeBox_SelectionChanged">
                        <ComboBoxItem Content="启动文件夹 (推荐)" IsSelected="True"/>
                        <ComboBoxItem Content="注册表启动项"/>
                        <ComboBoxItem Content="计划任务"/>
                        <ComboBoxItem Content="Windows 服务 (NSSM)"/>
                    </ComboBox>
                </Grid>
                
                <Grid x:Name="RegistryLocationPanel" Grid.Row="3" Margin="0,0,0,15" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="位置:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1976D2"/>
                    <ComboBox x:Name="RegistryLocationBox" Grid.Column="1" Padding="12,10" BorderBrush="#2196F3" BorderThickness="1" FontSize="13">
                        <ComboBoxItem Content="当前用户 (HKCU)" IsSelected="True"/>
                        <ComboBoxItem Content="系统全局 (HKLM) - 需管理员权限"/>
                    </ComboBox>
                </Grid>
                
                <Border x:Name="ServiceModePanel" Grid.Row="4" Margin="0,0,0,15" Background="#E3F2FD" CornerRadius="8" Padding="15" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="运行模式:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,15,0"/>
                        <StackPanel Grid.Column="1" Orientation="Vertical">
                            <RadioButton x:Name="BackgroundModeRadio" Content="后台运行（隐藏窗口，推荐）" IsChecked="True" Margin="0,0,0,8"/>
                            <RadioButton x:Name="ForegroundModeRadio" Content="前台运行（显示窗口）" Margin="0,0,0,8"/>
                            <TextBlock Text="提示：前台运行可以看到程序界面，适合需要交互的程序" FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <Border Grid.Row="5" CornerRadius="8" Padding="15">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#FFF3E0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=TypeBox, Path=SelectedIndex}" Value="3">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock x:Name="InfoText" Text="提示：启动文件夹方式最简单，无需特殊权限。程序会在用户登录时自动启动。" Foreground="#666" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消" Click="Cancel_Click" Padding="25,12" Margin="0,0,15,0" Background="#9E9E9E" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
            <Button Content="确定添加" Click="OK_Click" Padding="25,12" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
