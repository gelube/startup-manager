<Window x:Class="StartupManagerPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="启动管理器 Pro" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F5F7FA" Offset="0"/>
            <GradientStop Color="#E8ECF1" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#409EFF" Offset="0"/>
                        <GradientStop Color="#337ECC" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#66B1FF" Offset="0"/>
                                            <GradientStop Color="#409EFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#337ECC" Offset="0"/>
                                            <GradientStop Color="#2865A3" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#67C23A" Offset="0"/>
                        <GradientStop Color="#529B2E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#E6A23C" Offset="0"/>
                        <GradientStop Color="#B88230" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F56C6C" Offset="0"/>
                        <GradientStop Color="#C44141" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="#DCDFE6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="0" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Padding="24,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#409EFF" Offset="0"/>
                    <GradientStop Color="#337ECC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="启动管理器 Pro" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <TextBlock Text="Startup Manager Pro v3.0" FontSize="12" Foreground="#E6F1FF" Margin="0,4,0,0"/>
                </StackPanel>
                
                <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="4" Padding="12,6" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="支持系统：" Foreground="#333" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Windows 7 / 10 / 11" Foreground="#409EFF" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- 顶部工具栏 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16,12" Margin="16,16,16,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="添加" Style="{StaticResource PrimaryButtonStyle}" Click="AddNew_Click"/>
                <Button Content="启用" Style="{StaticResource SuccessButtonStyle}" Click="Enable_Click"/>
                <Button Content="禁用" Style="{StaticResource WarningButtonStyle}" Click="Disable_Click"/>
                <Button Content="删除" Style="{StaticResource DangerButtonStyle}" Click="Delete_Click"/>
                <Separator Margin="16,0" Background="#DCDFE6"/>
                <Border Background="#F5F7FA" CornerRadius="6" Padding="12,2" BorderBrush="#DCDFE6" BorderThickness="1">
                    <TextBox x:Name="SearchBox" Width="300" Padding="12,8" BorderThickness="0" Background="Transparent" FontSize="13" Foreground="#333" CaretBrush="#409EFF" TextChanged="SearchBox_TextChanged"/>
                </Border>
            </StackPanel>
        </Border>
        
        <!-- 主内容区 -->
        <Grid Grid.Row="2" Margin="16,16,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧分类 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Padding="16,12" BorderBrush="#EBEEF5" BorderThickness="0,0,0,1">
                        <TextBlock Text="分类" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                    </Border>
                    
                    <TreeView x:Name="CategoryTree" Grid.Row="1" BorderThickness="0" Background="Transparent" SelectedItemChanged="CategoryTree_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="12,8" Margin="8,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#ECF5FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" Margin="4,0">
                                        <TextBlock Text="{Binding Icon}" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Medium" Foreground="#333"/>
                                            <TextBlock Text="{Binding Count, StringFormat={}{0} 项}" FontSize="11" Foreground="#909399" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>
            
            <!-- 右侧列表 - 使用 DockPanel 消除空行 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="16,0,0,0">
                <DockPanel>
                    <!-- 详情面板（底部固定） -->
                    <Border DockPanel.Dock="Bottom" BorderBrush="#EBEEF5" BorderThickness="0,1,0,0" Padding="16" Background="#F9FAFB">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名称" FontWeight="Bold" Foreground="#606266" FontSize="13"/>
                            <TextBlock x:Name="DetailName" Grid.Row="0" Grid.Column="1" Foreground="#333" FontSize="13" Margin="0,0,0,8"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="厂商" FontWeight="Bold" Foreground="#606266" FontSize="13"/>
                            <TextBlock x:Name="DetailPublisher" Grid.Row="1" Grid.Column="1" Foreground="#333" FontSize="13" Margin="0,0,0,8"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="位置" FontWeight="Bold" Foreground="#606266" FontSize="13"/>
                            <TextBlock x:Name="DetailType" Grid.Row="2" Grid.Column="1" Foreground="#333" FontSize="13" Margin="0,0,0,8"/>
                            
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="打开位置" Click="OpenLocation_Click" Style="{StaticResource SuccessButtonStyle}" Padding="16,10" Margin="0,0,10,0"/>
                                <Button Content="删除" Click="Delete_Click" Style="{StaticResource DangerButtonStyle}" Padding="16,10"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- 数据列表（占据剩余空间） -->
                    <DataGrid x:Name="StartupGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="0" RowHeight="48" SelectionMode="Extended" Background="#FFFFFF" AlternatingRowBackground="#F5F7FA">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <ContextMenu.Template>
                                    <ControlTemplate>
                                        <Border Background="#FFFFFF" CornerRadius="6" BorderBrush="#DCDFE6" BorderThickness="1" Padding="4">
                                            <StackPanel IsItemsHost="True"/>
                                        </Border>
                                    </ControlTemplate>
                                </ContextMenu.Template>
                                <MenuItem x:Name="EnableMenu" Header="启用" Foreground="#333" Background="#FFFFFF"/>
                                <MenuItem x:Name="DisableMenu" Header="禁用" Foreground="#333" Background="#FFFFFF"/>
                                <Separator x:Name="ServiceSeparator" Background="#DCDFE6"/>
                                <MenuItem x:Name="ServiceAutoMenu" Header="自动" Foreground="#333" Background="#FFFFFF"/>
                                <MenuItem x:Name="ServiceManualMenu" Header="手动" Foreground="#333" Background="#FFFFFF"/>
                                <MenuItem x:Name="ServiceStopMenu" Header="停止" Foreground="#333" Background="#FFFFFF"/>
                                <MenuItem x:Name="ServiceStartMenu" Header="启动" Foreground="#333" Background="#FFFFFF"/>
                                <Separator Background="#DCDFE6"/>
                                <MenuItem Header="打开位置" Foreground="#333" Background="#FFFFFF"/>
                                <MenuItem Header="属性" Foreground="#333" Background="#FFFFFF"/>
                                <Separator Background="#DCDFE6"/>
                                <MenuItem Header="删除" Foreground="#333" Background="#FFFFFF"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F5F7FA"/>
                                <Setter Property="Foreground" Value="#333"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="BorderBrush" Value="#EBEEF5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="Foreground" Value="#333"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#ECF5FF"/>
                                        <Setter Property="Foreground" Value="#333"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F7FA"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Width="50"/>
                            <DataGridTextColumn Header="程序名称" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="厂商" Binding="{Binding Publisher}" Width="120"/>
                            <DataGridTextColumn Header="路径" Binding="{Binding Path}" Width="300"/>
                            <DataGridTextColumn Header="位置" Binding="{Binding Location}" Width="100"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
        
        <!-- 状态栏 -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="16,12" Margin="16,16,16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="#ECF5FF" CornerRadius="6" Padding="16,8" HorizontalAlignment="Left" BorderBrush="#D9ECFF" BorderThickness="1">
                    <TextBlock x:Name="StatusTotal" Text="共 0 项" FontWeight="Bold" Foreground="#409EFF" FontSize="14"/>
                </Border>
                
                <TextBlock Grid.Column="1" Text="启动管理器 Pro v3.0" Foreground="#909399" FontWeight="Medium" FontSize="13"/>
            </Grid>
        </Border>
    </Grid>
</Window>
