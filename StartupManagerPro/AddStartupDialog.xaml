<Window x:Class="StartupManagerPro.AddStartupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加启动项" Height="520" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        FontFamily="Microsoft YaHei UI">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="添加启动项" FontSize="24" FontWeight="Bold" Foreground="#333333"/>
            <TextBlock Text="选择类型并填写信息" FontSize="13" Foreground="#666666" Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- 表单 -->
        <StackPanel Grid.Row="1">
            <!-- 名称 -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="名称" FontSize="13" FontWeight="Medium" Foreground="#333333" Margin="0,0,0,8"/>
                <TextBox x:Name="NameBox" Padding="12,10" FontSize="14" 
                         BorderBrush="#E8E8E8" BorderThickness="1"
                         Foreground="#333333" Background="#FAFAFA"/>
            </StackPanel>
            
            <!-- 路径 -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="程序路径" FontSize="13" FontWeight="Medium" Foreground="#333333" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PathBox" Grid.Column="0" Padding="12,10" FontSize="14" 
                             BorderBrush="#E8E8E8" BorderThickness="1" Margin="0,0,8,0"
                             Foreground="#333333" Background="#FAFAFA"/>
                    <Button Grid.Column="1" Content="浏览" Click="Browse_Click" 
                            Padding="16,10" Background="#4A90D9" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontWeight="Medium"/>
                </Grid>
            </StackPanel>
            
            <!-- 类型 -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="启动类型" FontSize="13" FontWeight="Medium" Foreground="#333333" Margin="0,0,0,8"/>
                <ComboBox x:Name="TypeBox" Padding="12,10" FontSize="14" 
                          BorderBrush="#E8E8E8" BorderThickness="1"
                          Background="#FAFAFA" SelectionChanged="TypeBox_SelectionChanged">
                    <ComboBoxItem Content="📁 启动文件夹" IsSelected="True"/>
                    <ComboBoxItem Content="📝 注册表启动项"/>
                    <ComboBoxItem Content="📅 计划任务"/>
                    <ComboBoxItem Content="⚙️ Windows 服务"/>
                </ComboBox>
            </StackPanel>
            
            <!-- 注册表位置 -->
            <StackPanel x:Name="RegistryLocationPanel" Visibility="Collapsed" Margin="0,0,0,16">
                <TextBlock Text="注册表位置" FontSize="13" FontWeight="Medium" Foreground="#333333" Margin="0,0,0,8"/>
                <ComboBox x:Name="RegistryLocationBox" Padding="12,10" FontSize="14" 
                          BorderBrush="#E8E8E8" BorderThickness="1" Background="#FAFAFA">
                    <ComboBoxItem Content="👤 当前用户 (HKCU)" IsSelected="True"/>
                    <ComboBoxItem Content="🖥️ 系统全局 (HKLM) - 需管理员权限"/>
                </ComboBox>
            </StackPanel>
            
            <!-- 提示信息 -->
            <Border Background="#FFF7E6" CornerRadius="8" Padding="12">
                <TextBlock x:Name="InfoText" 
                           Text="💡 启动文件夹方式最简单，无需特殊权限。程序会在用户登录时自动启动。"
                           FontSize="12" Foreground="#666666" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
        
        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消" Click="Cancel_Click" 
                    Padding="20,10" Margin="0,0,8,0" 
                    Background="#F5F5F5" Foreground="#666666"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="✅ 确定添加" Click="OK_Click" 
                    Padding="20,10" 
                    Background="#4A90D9" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontWeight="Medium"/>
        </StackPanel>
    </Grid>
</Window>